# 복사해서 .env 로 사용: cp .env.example .env
# 로컬 개발은 기본값(USE_MOCK=true)이면 아무 키 없이 동작한다.

# mock(Zendesk/LLM 모두 가짜 응답) ↔ 실제 API 스위치
USE_MOCK=true

# ── Gemini (USE_MOCK=false 일 때 필수) ─────────────────────
GEMINI_API_KEY=
# 담당자가 선택 가능한 모델 후보 (콤마 구분)
AVAILABLE_MODELS=gemini-3.5-flash,gemini-3.5-flash-pro

# ── Zendesk Help Center (USE_MOCK=false 일 때 필수) ────────
ZENDESK_SUBDOMAIN=
ZENDESK_EMAIL=
ZENDESK_API_TOKEN=
ZENDESK_LOCALE=ko

# ── DB (기본: backend/sop_admin.db SQLite) ─────────────────
# DATABASE_URL=sqlite:///./sop_admin.db
